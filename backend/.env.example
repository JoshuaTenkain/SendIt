# ============================================================================
# SEND-IT Backend Configuration
# ============================================================================
# For development: copy this file to .env and use defaults where appropriate
# For production: generate secure random values and set all required variables
# ============================================================================

# Environment mode (dev or prod)
# In production, this enables strict validation of secrets and URLs
SENDIT_ENV=dev

# Database connection
# For production, use a managed database with strong credentials
SENDIT_DATABASE_URL=postgresql+psycopg://sendit:sendit@localhost:5432/sendit

# JWT Authentication (REQUIRED)
# Generate a random 32+ character string:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# DO NOT use "change-me" in production
SENDIT_JWT_SECRET_KEY=change-me-to-a-random-secret-key
SENDIT_JWT_ALGORITHM=HS256
SENDIT_JWT_ACCESS_TOKEN_EXP_MINUTES=60

# SendGrid Email Integration (optional)
SENDIT_SENDGRID_API_KEY=
SENDIT_SENDGRID_FROM_EMAIL=no-reply@send-it.local

# Twilio SMS Integration (optional)
SENDIT_TWILIO_ACCOUNT_SID=
SENDIT_TWILIO_AUTH_TOKEN=
SENDIT_TWILIO_FROM_NUMBER=

# PayFast Payment Integration (REQUIRED for production)
# Get credentials from https://www.payfast.co.za
# For development/testing, use sandbox credentials
SENDIT_PAYFAST_MERCHANT_ID=
SENDIT_PAYFAST_MERCHANT_KEY=
SENDIT_PAYFAST_PASSPHRASE=
SENDIT_PAYFAST_SANDBOX=true

# Google Maps API (optional)
SENDIT_GOOGLE_MAPS_API_KEY=

# The Courier Guy / Shiplogic Integration (optional)
SENDIT_TCG_ENABLED=false
SENDIT_TCG_BASE_URL=https://api.shiplogic.com
SENDIT_TCG_API_TOKEN=
SENDIT_TCG_WEBHOOK_SECRET=
SENDIT_TCG_DEFAULT_COLLECTION_EMAIL=ops@send-it.local
SENDIT_TCG_DEFAULT_COLLECTION_MOBILE=0000000000

# Aramex Integration (optional)
SENDIT_ARAMEX_ENABLED=false
SENDIT_ARAMEX_API_KEY=
SENDIT_ARAMEX_ACCOUNT_NUMBER=

# DHL Express Integration (optional)
SENDIT_DHL_ENABLED=false
SENDIT_DHL_API_KEY=

# Public URL Bases (REQUIRED for production)
# These are used in magic-link emails and payment callbacks
# Must be HTTPS in production
SENDIT_FRONTEND_BASE_URL=http://localhost:3000
SENDIT_API_BASE_URL=http://localhost:8000

# CORS Origins (REQUIRED for production)
# Comma-separated list of allowed frontend origins
SENDIT_CORS_ORIGINS=["http://localhost:3000"]

# Guest Magic-Link Tokens (REQUIRED)
# Generate a random 32+ character string:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# DO NOT use "change-me" in production
SENDIT_GUEST_TOKEN_SECRET=change-me-guest-secret
SENDIT_GUEST_TOKEN_MAX_AGE_HOURS=72

# Stripe Subscriptions (optional, future feature)
SENDIT_STRIPE_SECRET_KEY=
SENDIT_STRIPE_WEBHOOK_SECRET=

# VAT Rate (South Africa)
SENDIT_VAT_RATE_PCT=15
